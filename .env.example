# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here
ALLOWED_CHAT_IDS=your-chat-id-here

# Anthropic API (Claude Code icin)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Claude Code Ayarlari
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TURNS=50
CLAUDE_PERMISSIONS=skip

# Workspace (projeler buraya klonlanir)
WORKSPACE_DIR=/workspace

# Monitoring
VPN_CHECK_INTERVAL=30
WIFI_CHECK_INTERVAL=60
VPN_INTERFACE=wg0
VPN_ENDPOINT=10.0.0.1
